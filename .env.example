# Required
BROWSER_AGENT_KEY=your-secret-api-key-here
BROWSER_AGENT_PORT=3102

# Optional — Discord webhook for Cowork session notifications
# DISCORD_COWORK_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional — Cowork session persistence directories
# COWORK_SESSION_DIR=/path/to/cowork-sessions
# COWORK_REPO_DIR=/path/to/cowork-git-repo
